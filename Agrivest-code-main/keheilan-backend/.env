# =============================================================================
# .env
# Copy this file to .env and fill in real values before running the app.
# Never commit your .env file to version control.
# =============================================================================

# Railway PostgreSQL connection string — found in Railway dashboard > your DB > Connect tab
DATABASE_URL=sqlite:///keheilan.db

# Any random secret string — used to sign Flask sessions. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-string

# Gemini API key — free tier from https://aistudio.google.com → Get API Key
# Powers: Risk Profiler, Deal Ranker, Deal Explainer, Portfolio Narrator,
#         Text Rewriter, Viability Checker, Anomaly Detector, In-App Helper
GEMINI_API_KEY=AIzaSyArf7Tplvl9S2iTsg9s69mFeUI4jDwlccs

# Groq API key — free tier from https://console.groq.com → API Keys
# Powers: Whisper voice transcription (farmer voice notes)
GROQ_API_KEY=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

# S3 bucket name for farm photo uploads — create a bucket in AWS S3 console
AWS_S3_BUCKET=keheilan-farm-photos

# AWS IAM Access Key ID — create an IAM user with S3 permissions in AWS Console → IAM → Users
AWS_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE

# AWS IAM Secret Access Key — shown once when you create the IAM user, save it immediately
AWS_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Base URL of your N8N cloud instance — found in N8N Cloud dashboard (e.g. https://yourname.app.n8n.cloud)
N8N_WEBHOOK_BASE_URL=https://eyad7.app.n8n.cloud/webhook

# Set to True during development, False in production
FLASK_DEBUG=True
